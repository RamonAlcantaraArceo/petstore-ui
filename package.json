{
  "name": "petstore-ui",
  "version": "1.0.0",
  "description": "A modern React + TypeScript component library with Storybook documentation and Petstore demo",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run storybook",
    "prepare": "husky",
    "build": "bun run build-storybook && bun run build-petstore",
    "build:bundle-stats": "vite build --config vite.config.ts",
    "build-storybook": "storybook build",
    "build-website": "echo 'Static website uses public/ assets (no build step required)'",
    "build-petstore": "bun build src/petstore/index.tsx --outdir petstore/dist --minify",
    "preview": "bun run scripts/preview-server.ts",
    "storybook": "storybook dev -p 6006",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:visual": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@codecov/vite-plugin": "1.9.1",
    "@storybook/addon-a11y": "7.6.23",
    "@storybook/addon-controls": "^7.6.0",
    "@storybook/addon-docs": "^7.6.0",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-viewport": "^7.6.0",
    "@storybook/blocks": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/react-vite": "^7.6.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "latest",
    "@types/minimatch": "6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^0.6.15",
    "happy-dom": "14",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "storybook": "7.6.23",
    "typescript": "^5.0.0",
    "vite": "^5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  }
}
